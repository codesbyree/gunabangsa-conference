---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/shared/Navigation";
import Footer from "../components/shared/Footer.astro";
import SubPageHeader from "../components/shared/SubPageHeader.astro";
import CommitteeList from "../components/committee/CommitteeList.astro";
---

<Layout>
  <div
    class="min-h-screen bg-[#FDFDFD] font-['Plus_Jakarta_Sans',sans-serif] text-[#0A1A12] selection:bg-emerald-500 selection:text-white"
  >
    <Navigation currentPath="/committee" client:load />

    <SubPageHeader title="Committee" />
    <CommitteeList />

    <Footer />
  </div>
</Layout>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;400;600;700;800&display=swap");

  .animate-in {
    animation: enter 0.2s ease-out;
  }
  @keyframes enter {
    from {
      opacity: 0;
      transform: translateY(-0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
