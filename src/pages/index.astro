---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/shared/Navigation";
import Footer from "../components/shared/Footer.astro";
import Hero from "../components/home/Hero";
import HomeMarquee from "../components/home/HomeMarquee.astro";
import SponsorsMarquee from "../components/home/SponsorsMarquee.astro";
import ScopesSection from "../components/home/ScopesSection";
import AboutSection from "../components/home/AboutSection.astro";
import KeynotesSection from "../components/home/KeynotesSection.astro";
import DeadlinesSection from "../components/home/DeadlinesSection.astro";
import PricingSection from "../components/home/PricingSection";
import OrganizersPartners from "../components/home/OrganizersPartners.astro";
---

<Layout>
  <div
    class="min-h-screen bg-[#FDFDFD] font-['Plus_Jakarta_Sans',sans-serif] text-[#0A1A12] selection:bg-emerald-500 selection:text-white"
  >
    <Navigation currentPath="/" client:load />

    <Hero client:load />
    <SponsorsMarquee />
    <ScopesSection client:load />
    <AboutSection />
    <HomeMarquee />
    <KeynotesSection />
    <DeadlinesSection />
    <PricingSection client:load />

    <OrganizersPartners />
    <Footer />
  </div>
</Layout>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;400;600;700;800&display=swap");

  .animate-in {
    animation: enter 0.2s ease-out;
  }
  @keyframes enter {
    from {
      opacity: 0;
      transform: translateY(-0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
