---
import Layout from "../layouts/Layout.astro";
import HomeHeroSection from "../components/homepage/home-hero-section.astro";
import HomeScopeSection from "../components/homepage/home-scope-section";
import HomeAboutSection from "../components/homepage/home-about-section.astro";
import HomeSpeakersSection from "../components/homepage/home-speakers-section.astro";
import HomeDeadlinesSection from "../components/homepage/home-deadlines-section.astro";
import HomePricingSection from "../components/homepage/home-pricing-section";
---

<Layout>
  <HomeHeroSection />

  <div class="bg-teal-300 py-5 overflow-hidden border-y border-emerald-400">
    <div class="animate-marquee flex items-center gap-16 whitespace-nowrap will-change-transform">
      {
        [1, 2, 3, 4, 5, 6].map((i) => (
          <div class="flex items-center gap-16 text-emerald-950 font-black text-sm tracking-[0.2em] uppercase italic">
            <span>Scientific Research</span>
            <span class="w-2 h-2 rounded-full bg-emerald-950" />
            <span>Biomedical Innovation</span>
            <span class="w-2 h-2 rounded-full bg-emerald-950" />
            <span>Artificial Intelligence</span>
            <span class="w-2 h-2 rounded-full bg-emerald-950" />
            <span>Public Wellness</span>
            <span class="w-2 h-2 rounded-full bg-emerald-950" />
          </div>
        ))
      }
    </div>
  </div>

  <HomeScopeSection client:load />
  <HomeAboutSection />
  <HomeSpeakersSection />
  <HomeDeadlinesSection />
  <HomePricingSection client:load />
</Layout>;
