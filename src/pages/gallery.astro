---
import Layout from "../layouts/Layout.astro";
import SubPageHeader from "../components/shared/SubPageHeader.astro";
---

<Layout>
  <SubPageHeader title="Gallery" />

  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="mb-12 text-center text-slate-600 max-w-2xl mx-auto">
      <p class="leading-relaxed text-lg font-medium">
        Explore moments from our previous conferences and get a glimpse of the engaging sessions, networking events, and
        beautiful venues.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      <div
        class="aspect-video bg-slate-50 border border-slate-100 rounded-2xl p-2 shadow-xl shadow-emerald-950/5 overflow-hidden flex items-center justify-center hover:-translate-y-2 transition-all cursor-pointer"
      >
        <p class="text-slate-400 font-bold uppercase tracking-widest text-center text-xs">Gallery Image 1</p>
      </div>
      <div
        class="aspect-video bg-slate-50 border border-slate-100 rounded-2xl p-2 shadow-xl shadow-emerald-950/5 overflow-hidden flex items-center justify-center hover:-translate-y-2 transition-all cursor-pointer"
      >
        <p class="text-slate-400 font-bold uppercase tracking-widest text-center text-xs">Gallery Image 2</p>
      </div>
      <div
        class="aspect-video bg-slate-50 border border-slate-100 rounded-2xl p-2 shadow-xl shadow-emerald-950/5 overflow-hidden flex items-center justify-center hover:-translate-y-2 transition-all cursor-pointer"
      >
        <p class="text-slate-400 font-bold uppercase tracking-widest text-center text-xs">Gallery Image 3</p>
      </div>
      <div
        class="aspect-video bg-slate-50 border border-slate-100 rounded-2xl p-2 shadow-xl shadow-emerald-950/5 overflow-hidden flex items-center justify-center hover:-translate-y-2 transition-all cursor-pointer sm:flex"
      >
        <p class="text-slate-400 font-bold uppercase tracking-widest text-center text-xs">Gallery Image 4</p>
      </div>
      <div
        class="aspect-video bg-slate-50 border border-slate-100 rounded-2xl p-2 shadow-xl shadow-emerald-950/5 overflow-hidden flex items-center justify-center hover:-translate-y-2 transition-all cursor-pointer sm:flex"
      >
        <p class="text-slate-400 font-bold uppercase tracking-widest text-center text-xs">Gallery Image 5</p>
      </div>
      <div
        class="aspect-video bg-slate-50 border border-slate-100 rounded-2xl p-2 shadow-xl shadow-emerald-950/5 overflow-hidden flex items-center justify-center hover:-translate-y-2 transition-all cursor-pointer sm:flex"
      >
        <p class="text-slate-400 font-bold uppercase tracking-widest text-center text-xs">Gallery Image 6</p>
      </div>
    </div>
  </section>
</Layout>
