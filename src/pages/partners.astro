---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/shared/Navigation";
import Footer from "../components/shared/Footer.astro";
import SubPageHeader from "../components/shared/SubPageHeader.astro";
---

<Layout title="Our Partners | HEALTHMED-IC 2026">
  <div
    class="min-h-screen bg-[#FDFDFD] font-['Plus_Jakarta_Sans',sans-serif] text-[#0A1A12] selection:bg-emerald-500 selection:text-white"
  >
    <Navigation client:load currentPath="/partners" />

    <SubPageHeader title="Our Partners" />

    <section class="max-w-4xl mx-auto px-6 py-24">
      <div class="bg-slate-50 border border-slate-100 rounded-2xl p-8 mb-8 shadow-xl shadow-emerald-950/5">
        <h2 class="text-2xl font-bold text-[#062C1B] mb-6 tracking-tight">Sponsors and Global Partners</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
          <div
            class="bg-white p-6 rounded-xl border border-slate-100 flex items-center justify-center min-h-32 shadow-sm hover:-translate-y-1 transition-transform cursor-pointer"
          >
            <p class="text-slate-400 font-bold uppercase tracking-widest text-center text-xs">Partner Logo</p>
          </div>
          <div
            class="bg-white p-6 rounded-xl border border-slate-100 flex items-center justify-center min-h-32 shadow-sm hover:-translate-y-1 transition-transform cursor-pointer"
          >
            <p class="text-slate-400 font-bold uppercase tracking-widest text-center text-xs">Partner Logo</p>
          </div>
          <div
            class="bg-white p-6 rounded-xl border border-slate-100 flex items-center justify-center min-h-32 shadow-sm hover:-translate-y-1 transition-transform cursor-pointer"
          >
            <p class="text-slate-400 font-bold uppercase tracking-widest text-center text-xs">Partner Logo</p>
          </div>
          <div
            class="bg-white p-6 rounded-xl border border-slate-100 flex items-center justify-center min-h-32 shadow-sm hover:-translate-y-1 transition-transform cursor-pointer"
          >
            <p class="text-slate-400 font-bold uppercase tracking-widest text-center text-xs">Partner Logo</p>
          </div>
          <div
            class="bg-white p-6 rounded-xl border border-slate-100 flex items-center justify-center min-h-32 shadow-sm hover:-translate-y-1 transition-transform cursor-pointer"
          >
            <p class="text-slate-400 font-bold uppercase tracking-widest text-center text-xs">Partner Logo</p>
          </div>
          <div
            class="bg-white p-6 rounded-xl border border-slate-100 flex items-center justify-center min-h-32 shadow-sm hover:-translate-y-1 transition-transform cursor-pointer"
          >
            <p class="text-slate-400 font-bold uppercase tracking-widest text-center text-xs">Partner Logo</p>
          </div>
        </div>
        <p class="text-slate-600 mt-8 leading-relaxed text-sm font-medium">
          The HEALTHMED-IC 2026 conference is proudly supported by multiple academic institutions, healthcare
          organizations, and industry leaders. Detailed information about our partners and sponsorship opportunities
          will be announced soon.
        </p>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;400;600;700;800&display=swap");

  .animate-in {
    animation: enter 0.2s ease-out;
  }
  @keyframes enter {
    from {
      opacity: 0;
      transform: translateY(-0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
