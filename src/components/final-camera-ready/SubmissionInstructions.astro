---
import { FileCode, ShieldCheck, Download, Mail, UserCheck, Phone } from "lucide-react";
---

<div class="max-w-6xl mx-auto px-6 py-24 space-y-24">
  {/* Introduction Section */}
  <section class="space-y-8">
    <div class="flex items-center gap-4 border-b border-slate-100 pb-8">
      <FileCode className="w-8 h-8 text-emerald-600" />
      <h2 class="text-3xl font-black text-[#062C1B] tracking-tighter uppercase leading-tight">
        Final Camera-Ready Submission Instructions
      </h2>
    </div>
    <div class="bg-emerald-50/50 p-8 rounded-3xl border border-emerald-100/50">
      <p class="text-lg text-slate-700 leading-relaxed font-medium mb-4">
        All manuscripts identified as requiring revision will undergo a subsequent review process. Authors are expected
        to prepare a clean <strong>Revised Manuscript</strong> and a separate <strong>Response to Reviewers</strong> document,
        clearly outlining how each reviewer’s comment has been addressed.
      </p>
      <p class="text-lg text-slate-700 leading-relaxed font-medium">
        After completing all revisions, all accepted papers must be prepared as a <strong
          >Final Camera-Ready Manuscript</strong
        >. This is the final step in the submission process, required after your paper has been officially accepted for
        publication.
      </p>
    </div>
  </section>

  {/* Preparing the Final Camera-Ready Manuscript Section */}
  <section class="space-y-12">
    <div class="flex items-center gap-4 border-b border-slate-100 pb-8">
      <FileCode className="w-8 h-8 text-emerald-600" />
      <h3 class="text-2xl font-black text-[#062C1B] tracking-tighter uppercase leading-tight">
        Important Notes for Authors
      </h3>
    </div>

    <p class="text-sm text-slate-600 leading-relaxed font-medium mb-8">
      In preparing the Final Camera-Ready Manuscript, please ensure the following:
    </p>

    <div class="grid md:grid-cols-2 gap-x-12 gap-y-10">
      {
        [
          "The Final Camera-Ready Manuscript must include author names, affiliations, and email addresses (as required by the publisher’s template).",
          "Strictly follow the writing instructions provided in the publisher’s template (from title to references).",
          "Use clear and high-resolution figures; avoid or replace any blurred images.",
          "If figures are reproduced from other sources, the corresponding copyright permission form must be provided for each figure.",
          "Use a reference management tool (e.g., Mendeley, Zotero) to minimize formatting errors in the references section.",
          "The prepared Final Camera-Ready Manuscript, along with all required documents, must then be resubmitted through the IGERS system.",
        ].map((text, i) => (
          <div class="flex gap-6 group">
            <div class="w-10 h-10 bg-[#062C1B] rounded-lg shrink-0 flex items-center justify-center font-black text-white text-sm group-hover:bg-emerald-500 transition-colors">
              {i + 1}
            </div>
            <p class="text-sm text-slate-600 leading-relaxed font-medium">{text}</p>
          </div>
        ))
      }
    </div>
  </section>

  {/* Formatting and Editing Assistance Section */}
  <section class="space-y-12">
    <div class="bg-slate-900 rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
      <div class="absolute right-0 bottom-0 p-10 opacity-5 pointer-events-none">
        <UserCheck className="w-48 h-48" />
      </div>
      <div class="relative z-10 flex flex-col md:flex-row gap-12 items-center justify-between">
        <div class="flex-1 max-w-2xl">
          <h4 class="text-emerald-500 text-[10px] font-black uppercase tracking-[0.3em] mb-4">Assistance</h4>
          <p class="text-2xl font-bold mb-6 leading-tight">Manuscript Formatting and Editing Assistance</p>
          <p class="text-sm text-slate-400 font-medium leading-relaxed">
            We understand that preparing the final camera-ready manuscript can be challenging. Therefore, we offer a
            professional formatting and editing service through our trusted partner to assist you with all requirements
            for your final camera-ready submission.
          </p>
        </div>
        <div
          class="flex flex-col gap-4 bg-white/10 p-8 rounded-3xl border border-white/10 w-full md:w-auto min-w-[300px]"
        >
          <h5 class="font-bold text-white mb-2">Our Partner Contact</h5>
          <div class="flex items-center gap-3">
            <Mail className="w-5 h-5 text-emerald-400" />
            <a href="mailto:nutral@nusaputra.ac.id" class="text-sm hover:text-emerald-400 transition-colors font-medium"
              >nutral@nusaputra.ac.id</a
            >
          </div>
          <div class="flex items-center gap-3">
            <Phone className="w-5 h-5 text-emerald-400" />
            <span class="text-sm font-medium">+628 111 884 108</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Templates Section (Reused from Initial Submission for consistency) */}
  <div class="space-y-10">
    <div class="flex items-center gap-4">
      <FileCode className="w-6 h-6 text-emerald-600" />
      <h3 class="text-2xl font-black text-[#062C1B] tracking-tighter uppercase leading-tight">Template Resources</h3>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      <a
        href="#"
        class="flex items-center justify-between p-8 bg-white border border-slate-200 rounded-3xl hover:border-emerald-500 hover:shadow-xl transition-all group"
      >
        <div>
          <h4 class="font-bold text-[#062C1B] mb-1">IEEE MS Word Template</h4>
          <p class="text-xs text-slate-400">Standard .docx format</p>
        </div>
        <div
          class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-300 group-hover:bg-emerald-500 group-hover:text-white transition-all"
        >
          <Download className="w-5 h-5" />
        </div>
      </a>
      <a
        href="#"
        class="flex items-center justify-between p-8 bg-white border border-slate-200 rounded-3xl hover:border-emerald-500 hover:shadow-xl transition-all group"
      >
        <div>
          <h4 class="font-bold text-[#062C1B] mb-1">IEEE LaTeX Template</h4>
          <p class="text-xs text-slate-400">Source / Overleaf</p>
        </div>
        <div
          class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-300 group-hover:bg-emerald-500 group-hover:text-white transition-all"
        >
          <Download className="w-5 h-5" />
        </div>
      </a>
    </div>
  </div>
</div>
