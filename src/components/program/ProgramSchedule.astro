---
import { SCHEDULE } from "../../data/constants";
import { Calendar, ArrowRight, FileText } from "lucide-react";
---

<div class="max-w-5xl mx-auto px-6 py-24">
  <div class="bg-white border border-slate-100 rounded-3xl overflow-hidden shadow-sm">
    <div class="bg-[#062C1B] p-6 text-white flex justify-between items-center">
      <div class="font-bold flex items-center gap-2">
        <Calendar className="w-5 h-5 text-emerald-400" />Day 01 — Nov 5, 2026
      </div>
      <div class="text-xs font-black uppercase tracking-widest text-emerald-400/60">Main Auditorium</div>
    </div>
    <div class="divide-y divide-slate-50">
      {
        SCHEDULE.map((item, i) => (
          <div class="group flex flex-col md:flex-row md:items-center p-8 hover:bg-emerald-50/30 transition-colors">
            <div class="w-40 shrink-0 mb-2 md:mb-0">
              <span class="text-sm font-bold text-emerald-600 font-mono tracking-tighter">{item.time}</span>
            </div>
            <div class="flex-1">
              <h4 class="text-lg font-extrabold text-[#062C1B] leading-tight group-hover:text-emerald-800 transition-colors">
                {item.activity}
              </h4>
              <div class="mt-2 flex items-center gap-2">
                <span
                  class={`text-[10px] font-black uppercase tracking-widest px-2 py-0.5 rounded ${
                    item.type === "Keynote"
                      ? "bg-emerald-500 text-emerald-950"
                      : item.type === "Scientific"
                      ? "bg-slate-900 text-white"
                      : "bg-slate-100 text-slate-500"
                  }`}
                >
                  {item.type}
                </span>
              </div>
            </div>
            <div class="mt-4 md:mt-0 opacity-0 group-hover:opacity-100 transition-opacity">
              <ArrowRight className="w-5 h-5 text-emerald-500" />
            </div>
          </div>
        ))
      }
    </div>
  </div>
  <div
    class="mt-12 p-8 bg-slate-50 border border-slate-100 rounded-2xl flex flex-col md:flex-row items-center justify-between gap-6"
  >
    <div class="flex items-start gap-4">
      <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center shadow-sm text-emerald-600">
        <FileText className="w-6 h-6" />
      </div>
      <div>
        <h4 class="font-bold text-[#062C1B]">Detailed Abstract eBook?</h4><p class="text-sm text-slate-500 font-medium">
          Download the full program schedule in PDF.
        </p>
      </div>
    </div>
    <button
      class="bg-[#062C1B] text-white px-8 py-3 rounded-lg font-black text-xs uppercase tracking-widest hover:bg-emerald-600 transition active:scale-95"
      >Download PDF</button
    >
  </div>
</div>
