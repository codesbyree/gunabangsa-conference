const itSupport = [
  { role: "Member", name: "Muhammad Ikhsan Thohir, M.Kom.", affiliation: "Nusa Putra University" },
  { role: "Member", name: "M. Haikal Irhamna, S.Kom.", affiliation: "Nusa Putra University" },
  { role: "Member", name: "Ujang Herlan", affiliation: "Nusa Putra University" },
];

const sections = [
  { title: "Organizing Committee", icon: Users, data: organizing },
  { title: "International Advisory Committee", icon: Globe2, data: international },
  { title: "Scientific / Technical Program Committee", icon: FlaskConical, data: scientific },
  { title: "IT and Technical Support Committee", icon: MonitorDot, data: itSupport },
];
---

<div class="max-w-6xl mx-auto px-6 py-24 space-y-20">
  <div class="text-center max-w-3xl mx-auto mb-16">
    <p class="text-xl text-slate-600 font-medium leading-relaxed">Meet the people behind this prestigious event.</p>
  </div>

  {
    sections.map((section) => (
      <section class="space-y-8 relative">
        <div class="flex items-center gap-4 border-b border-slate-200 pb-6 mb-8">
          <div class="w-12 h-12 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center shrink-0">
            <section.icon className="w-6 h-6" />
          </div>
          <h2 class="text-3xl font-black text-emerald-950 tracking-tighter uppercase leading-tight">{section.title}</h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {section.data.map((member) => (
            <div class="bg-white border border-slate-200 rounded-3xl p-8 hover:border-emerald-400 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
              <div class="inline-block px-3 py-1 rounded-full bg-slate-100 text-slate-600 font-bold text-xs tracking-widest uppercase mb-4 group-hover:bg-emerald-500 group-hover:text-emerald-950 transition-colors">
                {member.role}
              </div>
              <h3 class="text-lg font-bold text-emerald-950 mb-2 leading-snug">{member.name}</h3>
              <p class="text-sm text-slate-500 font-medium">{member.affiliation}</p>
            </div>
          ))}
        </div>
      </section>
    ))
  }
</div>
