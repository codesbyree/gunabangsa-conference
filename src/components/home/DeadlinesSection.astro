---
import { DEADLINES } from "../../data/constants";
import { Calendar, Clock } from "lucide-react";
---

<section id="deadlines" class="py-24 bg-[#062C1B] relative overflow-hidden">
  <div class="absolute top-0 right-0 p-20 opacity-10 pointer-events-none">
    <Calendar className="w-96 h-96 text-white" />
  </div>
  <div class="max-w-4xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <div class="text-emerald-400 text-[10px] font-black uppercase tracking-[0.4em] mb-4">Timeline</div>
      <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6">Submission Deadlines</h2>
    </div>
    <div class="space-y-4">
      {
        DEADLINES.map((item, idx) => (
          <div class="flex flex-col md:flex-row md:items-center justify-between p-6 bg-white/5 border border-white/10 rounded-lg group hover:border-emerald-500 transition-colors">
            <div class="flex items-center gap-6 mb-4 md:mb-0">
              <div class="w-12 h-12 flex items-center justify-center bg-white/5 rounded-md text-emerald-400 group-hover:bg-emerald-500 group-hover:text-emerald-950 transition-all">
                <Clock className="w-5 h-5" />
              </div>
              <div>
                <h4 class="text-white font-bold text-lg">{item.event}</h4>
                {item.description && <p class="text-gray-400 text-sm mt-1 mb-2">{item.description}</p>}
                <p class="text-emerald-500/50 text-xs font-bold uppercase tracking-widest">{item.date}</p>
              </div>
            </div>
            <div
              class={`px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest text-center w-fit ${
                item.status === "Open" ? "bg-emerald-500 text-emerald-950" : "bg-white/10 text-white/40"
              }`}
            >
              {item.status}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
