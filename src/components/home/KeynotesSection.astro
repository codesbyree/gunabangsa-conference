---
import { SPEAKERS } from "../../data/constants";
import { ExternalLink } from "lucide-react";
---

<section id="speakers" class="py-24 bg-[#FDFDFD]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl font-extrabold text-[#062C1B] mb-6">Distinguished Keynotes</h2>
      <div class="w-20 h-1.5 bg-emerald-500 mx-auto rounded-full"></div>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        SPEAKERS.map((speaker) => (
          <div class="group relative h-[560px] overflow-hidden rounded-xl bg-emerald-950 border border-slate-200">
            <div class="absolute inset-0 bg-linear-to-br from-emerald-900/50 to-emerald-950/80 transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-linear-to-t from-black via-black/40 to-transparent" />
            <div class="absolute bottom-0 left-0 p-8 z-10 transition-all duration-500 group-hover:opacity-0 group-hover:translate-y-4">
              <h4 class="text-2xl font-black text-white leading-tight mb-2 tracking-tighter">{speaker.name}</h4>
              <p class="text-emerald-400 text-xs font-bold uppercase tracking-widest mb-1">{speaker.title}</p>
              <p class="text-white/40 text-xs font-medium italic">{speaker.affiliation}</p>
            </div>
            <div class="absolute inset-x-0 bottom-0 h-[80%] bg-white translate-y-full transition-transform duration-500 ease-in-out group-hover:translate-y-0 p-8 flex flex-col z-20">
              <div class="flex items-center justify-between border-b border-slate-100 pb-6 mb-6">
                <div class="flex flex-col">
                  <span class="text-emerald-600 text-[10px] font-black uppercase tracking-widest mb-1">
                    Keynote Speaker
                  </span>
                  <h4 class="text-xl font-extrabold text-[#062C1B] leading-tight">{speaker.name}</h4>
                </div>
                <ExternalLink className="w-4 h-4 text-slate-300" />
              </div>
              <div class="flex-1 overflow-y-auto custom-scrollbar pr-2">
                <p class="text-xs font-bold text-emerald-700 uppercase mb-3 tracking-tighter">Academic Background</p>
                <p class="text-sm text-slate-600 leading-relaxed font-medium mb-6 italic">"{speaker.bio}"</p>
                <div class="space-y-4">
                  <div class="p-3 bg-slate-50 border-l-2 border-emerald-500">
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">Topic</p>
                    <p class="text-xs font-bold text-slate-800 leading-tight">Advanced Medical Systems Integration</p>
                  </div>
                  <div class="p-3 bg-slate-50 border-l-2 border-emerald-500">
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">Session</p>
                    <p class="text-xs font-bold text-slate-800 leading-tight">Nov 5, 11:30 (Stage 01)</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
