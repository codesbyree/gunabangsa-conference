---
import {
  Instagram,
  Twitter,
  MessageCircle,
  Mail,
  ArrowRight,
  Facebook,
  Youtube,
  PhoneIcon,
  MailIcon,
} from "lucide-react";

import HomeMarquee from "../home/HomeMarquee.astro";
---

<HomeMarquee />

<footer class="bg-emerald-950 pt-24 pb-12">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-12 mb-20">
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-8 h-8 bg-emerald-900 rounded flex items-center justify-center font-bold text-white italic">
            H
          </div>
          <span class="font-extrabold text-white tracking-tighter text-2xl">HEALTHMED-IC</span>
        </div>
        <p class="text-slate-400 text-sm font-medium leading-relaxed max-w-sm mb-10">
          The definitive international summit for medical excellence and technological advancement in life sciences.
          Facilitating global scientific dialogue.
        </p>
        <div class="flex gap-3">
          <a
            href="#"
            aria-label="Facebook"
            class="w-[42px] h-[42px] bg-emerald-500 rounded-full flex items-center justify-center hover:-translate-y-1 transition-transform cursor-pointer"
          >
            <Facebook className="w-[18px] h-[18px] text-emerald-950" fill="currentColor" />
          </a>
          <a
            href="#"
            aria-label="Twitter"
            class="w-[42px] h-[42px] bg-emerald-500 rounded-full flex items-center justify-center hover:-translate-y-1 transition-transform cursor-pointer"
          >
            <Twitter className="w-[18px] h-[18px] text-emerald-950" fill="currentColor" />
          </a>
          <a
            href="#"
            aria-label="Instagram"
            class="w-[42px] h-[42px] bg-emerald-500 rounded-full flex items-center justify-center hover:-translate-y-1 transition-transform cursor-pointer"
          >
            <Instagram className="w-[18px] h-[18px] text-emerald-950" />
          </a>
          <a
            href="#"
            aria-label="Youtube"
            class="w-[42px] h-[42px] bg-emerald-500 rounded-full flex items-center justify-center hover:-translate-y-1 transition-transform cursor-pointer"
          >
            <Youtube className="w-[18px] h-[18px] text-emerald-950" />
          </a>
        </div>
      </div>
      <div>
        <h4 class="text-xl font-bold text-slate-50 mb-8 tracking-tight">Quick Actions</h4>
        <ul class="space-y-5 text-[15px] font-medium text-slate-400">
          <li><a href="/" class="hover:text-emerald-700 transition">Abstract Submission</a></li>
          <li><a href="/program" class="hover:text-emerald-700 transition">Conference Program</a></li>
          <li><a href="/" class="hover:text-emerald-700 transition">Ethical Guidelines</a></li>
          <li><a href="/" class="hover:text-emerald-700 transition">Committees</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xl font-bold text-slate-50 mb-8 tracking-tight">Contact</h4>
        <div class="space-y-5 text-[15px] font-medium">
          <a href="" class="flex items-center gap-4 text-slate-500 hover:text-emerald-700 transition">
            <PhoneIcon className="w-4 h-4 text-emerald-800" />
            <span>(000) 000-0000</span>
          </a>

          <a href="" class="flex items-center gap-4 text-slate-500 hover:text-emerald-700 transition">
            <MailIcon className="w-4 h-4 text-emerald-800" />
            <span>info@healthmed-ic.org</span>
          </a>
        </div>
      </div>
    </div>
    <div
      class="pt-12 border-t border-slate-100 flex flex-col md:flex-row justify-between items-center text-[10px] font-black uppercase tracking-widest text-slate-300"
    >
      <p>© 2026 HEALTHMED-IC Scientific Committee. All rights reserved.</p>
    </div>
  </div>
</footer>
