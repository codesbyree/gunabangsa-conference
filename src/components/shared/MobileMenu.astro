---
interface Props {
  authorLinks: Array<{ href: string; label: string }>;
  moreLinks: Array<{ href: string; label: string }>;
}

const { authorLinks, moreLinks } = Astro.props;
---

<div
  id="mobile-menu"
  class="hidden md:hidden absolute top-full left-0 right-0 mt-2 px-4 animate-in fade-in zoom-in-95 duration-200"
>
  <div class="bg-emerald-900 rounded-2xl border border-white/10 p-6 flex flex-col gap-4 shadow-2xl">
    <a href="/" class="text-left text-white font-bold text-sm tracking-widest block">HOME</a>
    <a href="/venue" class="text-left text-white font-bold text-sm tracking-widest block">VENUE</a>
    <a href="/committee" class="text-left text-white font-bold text-sm tracking-widest block">COMMITTEE</a>
    <a href="/registration" class="text-left text-white font-bold text-sm tracking-widest block">REGISTRATIONS</a>

    <div class="border-t border-white/10 pt-4">
      <span class="text-[10px] font-black text-emerald-500 uppercase tracking-[0.2em] mb-2 block"> Author Info</span>
      <div class="flex flex-col gap-3">
        {
          authorLinks.map((link) => (
            <a href={link.href} class="block text-left text-white/70 font-bold text-sm tracking-widest">
              {link.label}
            </a>
          ))
        }
      </div>
    </div>

    <div class="border-t border-white/10 pt-4">
      <span class="text-[10px] font-black text-emerald-500 uppercase tracking-[0.2em] mb-2 block">
        More Information
      </span>
      <div class="flex flex-col gap-3">
        {
          moreLinks.map((link) => (
            <a href={link.href} class="block text-left text-white/70 font-bold text-sm tracking-widest">
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>
