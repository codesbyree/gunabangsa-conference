---
import { ArrowRightIcon, InstagramIcon, MailIcon, MessageCircleIcon, TwitterIcon } from "lucide-react";

const navigationLinks = [
  { name: "Home", url: "/" },
  { name: "Program", url: "/program" },
  { name: "Comittee", url: "/comittee" },
];
---

<footer class="bg-white pt-24 pb-12 border-t border-slate-100">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-12 mb-20">
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-8 h-8 bg-[#062C1B] rounded flex items-center justify-center font-bold text-white italic">H</div>
          <span class="font-extrabold text-[#062C1B] tracking-tighter text-2xl"> HEALTHMED-IC </span>
        </div>
        <p class="text-slate-500 text-sm font-medium leading-relaxed max-w-sm mb-10">
          The definitive international summit for medical excellence and technological advancement in life sciences.
          Facilitating global scientific dialogue.
        </p>

        <div class="flex gap-4">
          <a
            href="/"
            aria-label="Instagram"
            class="w-10 h-10 border border-slate-200 rounded flex items-center justify-center hover:bg-emerald-500 hover:border-emerald-500 hover:text-white transition-all cursor-pointer group"
          >
            <InstagramIcon className="h-4 w-4" />
          </a>
        </div>
      </div>

      <div>
        <h4 class="text-[#062C1B] font-black text-xs uppercase tracking-[0.2em] mb-8">Navigation</h4>
        <ul class="space-y-4 text-sm font-bold text-slate-400">
          {
            navigationLinks.map((navlink) => (
              <li>
                <a href={navlink.url} class="hover:text-emerald-600 transition">
                  {navlink.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="text-[#062C1B] font-black text-xs uppercase tracking-[0.2em] mb-8">Secretariat</h4>
        <p class="text-sm font-bold text-slate-800 mb-2">Global Health Council Office</p>
        <p class="text-sm text-slate-400 mb-6">info@healthmed-ic.org</p>
        <button class="text-emerald-600 text-xs font-black uppercase tracking-widest flex items-center gap-2">
          Get In Touch <ArrowRightIcon className="w-3 h-3" />
        </button>
      </div>
    </div>

    <div
      class="pt-12 border-t border-slate-100 flex flex-col md:flex-row justify-between items-center text-[10px] font-black uppercase tracking-widest text-slate-300"
    >
      <p>© 2026 HEALTHMED-IC Scientific Committee. All rights reserved.</p>
      <div class="flex gap-8 mt-6 md:mt-0">
        <a href="#" class="hover:text-emerald-600 transition"> Privacy Protocol </a>
        <a href="#" class="hover:text-emerald-600 transition"> Publication Ethics </a>
      </div>
    </div>
  </div>
</footer>
